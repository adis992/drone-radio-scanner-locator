NODE_ENV=production
PORT=3001
WS_PORT=3001

# RTL-SDR Configuration
RTL_DEVICE_INDEX=0
RTL_SAMPLE_RATE=2048000
RTL_GAIN=0

# Scanning Configuration
SCAN_INTERVAL=2000
ENABLE_ADSB=true
ENABLE_IOT=true
ENABLE_BLUETOOTH=true
ENABLE_SPECTRUM=true

# Recording Configuration
RECORDING_SAMPLE_RATE=48000
RECORDING_FORMAT=wav
RECORDING_BITRATE=16

# Frequencies to scan (in Hz)
DRONE_FREQUENCIES=2400000000,5800000000,433920000,915000000
IOT_FREQUENCIES=433920000,868000000,315000000,915000000
